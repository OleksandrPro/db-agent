services:
  agent:
    volumes:
      - ./src:/app/src
    environment:
      - DB_HOST=db-prod
      - TEST_DB_HOST=db-test
    depends_on:
      - db-prod
    stdin_open: true
    tty: true

  db-prod:
    image: postgres:15-alpine
    environment:
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: ${DB_NAME}
    ports:
      - "${EXTERNAL_PROD_PORT}:5432"
    volumes:
      - prod_data:/var/lib/postgresql/data

  db-test:
    ports:
      - "${EXTERNAL_TEST_PORT}:5432"

volumes:
  prod_data: